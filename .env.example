# Optional local override for the persistent data directory.
# Railway automatically provides RAILWAY_VOLUME_MOUNT_PATH when a Volume is attached.
DATA_DIR="./data"

# Auth settings. Set real values in your deployment environment.
APP_PASSWORD="replace-with-a-real-login-password"
AUTH_SECRET="replace-with-a-long-random-session-secret"
AUTH_TOKEN_TTL_MS="28800000"

# Upload settings. Defaults are 10 MB per file and 20 MB per request.
JSON_BODY_LIMIT="30mb"
MAX_UPLOAD_FILE_BYTES="10485760"
MAX_UPLOAD_BATCH_BYTES="20971520"

# Keep disabled unless you intentionally need the admin clear-records API.
ENABLE_RECORD_DELETE="false"
