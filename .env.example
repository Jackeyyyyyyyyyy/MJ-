# Optional local override for the persistent data directory.
# Railway automatically provides RAILWAY_VOLUME_MOUNT_PATH when a Volume is attached.
DATA_DIR="./data"

# Auth settings. Set real values in your deployment environment.
# The super admin is the only account controlled by environment variables.
SUPER_ADMIN_USERNAME="developer"
SUPER_ADMIN_NAME="超级管理员"
SUPER_ADMIN_PASSWORD="replace-with-a-real-super-admin-password"
APP_PASSWORD="replace-with-a-real-login-password"
AUTH_SECRET="replace-with-a-long-random-session-secret"
AUTH_TOKEN_TTL_MS="28800000"

# Backup export access. Set real values only in deployment/local environment variables.
BACKUP_ADMIN_USER="replace-with-a-backup-admin-username"
BACKUP_ADMIN_PASSWORD="replace-with-a-backup-admin-password"
BACKUP_TOKEN_TTL_MS="1800000"
BACKUP_UPLOAD_LIMIT_BYTES="314572800"

# Upload settings. Defaults are 10 MB per file and 20 MB per request.
JSON_BODY_LIMIT="30mb"
MAX_UPLOAD_FILE_BYTES="10485760"
MAX_UPLOAD_BATCH_BYTES="20971520"

# AI approval suggestions. Keep real API keys only in local/deployment env vars.
OPENAI_API_KEY="replace-with-your-ai-api-key"
OPENAI_API_BASE="https://api.openai.com/v1"
OPENAI_MODEL="replace-with-your-model"
AI_REQUEST_TIMEOUT_MS="12000"

# Web Push notifications for installed PWA shortcuts.
# Generate keys with: npm run push:keys
# If these keys are omitted, the server auto-generates persistent keys in DATA_DIR.
WEB_PUSH_SUBJECT="mailto:admin@example.com"
WEB_PUSH_VAPID_PUBLIC_KEY="replace-with-generated-public-key"
WEB_PUSH_VAPID_PRIVATE_KEY="replace-with-generated-private-key"
# WEB_PUSH_AUTO_GENERATE="true"
